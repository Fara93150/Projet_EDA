   "source": [
    "for col in variables_analyse:\n",
    "    mediane = df_subset[col].median()\n",
    "    q1 = np.percentile(df_subset[col], 25)\n",
    "    q3 = np.percentile(df_subset[col], 75)\n",
    "    iqr = q3 - q1\n",
    "    mad = np.median(np.abs(df_subset[col] - mediane))\n",
    "    \n",
    "    print(f\"--- {col} ---\")\n",
    "    print(\"Médiane :\", mediane)\n",
    "    print(\"Q1      :\", q1)\n",
    "    print(\"Q3      :\", q3)\n",
    "    print(\"IQR     :\", iqr)\n",
    "    print(\"MAD     :\", mad)\n",
    "    print()"
   ]
